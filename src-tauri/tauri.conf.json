{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Waifudex",
  "version": "0.1.0",
  "identifier": "com.kentakang.waifudex",
  "build": {
    "beforeDevCommand": "pnpm dev -- --host 0.0.0.0 --port 1420",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Waifudex",
        "width": 420,
        "height": 720,
        "visible": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "shadow": false,
        "resizable": true,
        "skipTaskbar": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "../third_party/inochi2d-c/out/libinochi2d-c.so"
    ],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
