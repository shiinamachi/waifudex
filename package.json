{
  "name": "waifudex",
  "version": "0.1.7",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.32.1",
  "scripts": {
    "version:sync": "node ./scripts/sync-app-version.mjs",
    "dependencies:generate": "node ./scripts/generate-dependency-inventory.mjs",
    "dev": "node ./scripts/generate-dependency-inventory.mjs && vite",
    "build": "node ./scripts/generate-dependency-inventory.mjs && vite build",
    "inochi2d:build": "./scripts/build-inochi2d.sh",
    "inochi2d:build:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%INIT_CWD%\\scripts\\build-inochi2d-windows.ps1\"",
    "preview": "vite preview",
    "check": "node ./scripts/generate-dependency-inventory.mjs && tsc --noEmit -p ./tsconfig.json && tsc --noEmit -p ./tsconfig.node.json",
    "tauri": "tauri",
    "tauri:dev": "node ./scripts/sync-app-version.mjs && node ./scripts/generate-dependency-inventory.mjs && tauri dev",
    "tauri:dev:wsl": "./scripts/tauri-dev-windows.sh",
    "tauri:build": "node ./scripts/sync-app-version.mjs && node ./scripts/generate-dependency-inventory.mjs && tauri build",
    "tauri:build:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%INIT_CWD%\\scripts\\tauri-build-windows-host.ps1\"",
    "tauri:release:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File \"%INIT_CWD%\\scripts\\tauri-release-windows-host.ps1\"",
    "updater:manifest": "node ./scripts/generate-updater-json.mjs"
  },
  "dependencies": {
    "@fluentui/react-components": "9.73.4",
    "@tauri-apps/api": "2.10.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "the-new-css-reset": "1.11.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "2.10.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vanilla-extract/css": "1.20.0",
    "@vanilla-extract/vite-plugin": "5.2.1",
    "@vitejs/plugin-react": "6.0.1",
    "typescript": "5.9.3",
    "vite": "8.0.0"
  }
}
