{
    "name": "waifudex",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "packageManager": "pnpm@10.32.1",
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "inochi2d:build": "./scripts/build-inochi2d.sh",
        "inochi2d:build:windows": "./scripts/build-inochi2d-windows.sh",
        "preview": "vite preview",
        "check": "svelte-check --tsconfig ./tsconfig.json",
        "test": "vitest",
        "tauri": "tauri",
        "tauri:dev": "tauri dev",
        "tauri:dev:windows": "pnpm inochi2d:build:windows && CARGO_TARGET_X86_64_PC_WINDOWS_MSVC_RUNNER=../scripts/wsl-exec.sh tauri dev --runner cargo-xwin --target x86_64-pc-windows-msvc",
        "tauri:build": "tauri build",
        "tauri:build:windows": "pnpm inochi2d:build:windows && pnpm tauri build --runner cargo-xwin --target x86_64-pc-windows-msvc --no-bundle"
    },
    "dependencies": {
        "@tauri-apps/api": "2.10.1",
        "svelte": "5.53.12"
    },
    "devDependencies": {
        "@sveltejs/vite-plugin-svelte": "7.0.0",
        "@tauri-apps/cli": "2.10.1",
        "@tsconfig/svelte": "5.0.8",
        "@types/node": "25.5.0",
        "svelte-check": "4.4.5",
        "typescript": "5.9.3",
        "vite": "8.0.0",
        "vitest": "4.1.0"
    }
}
